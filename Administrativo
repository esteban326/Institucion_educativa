public class Administrativo extends Persona {
    private String cargo;
    private String dependencia;
    private double salarioFijo;

    public Administrativo(int id, String nombre, int edad, String cargo, String dependencia, int salario) {
        super(id, nombre, edad);
        this.cargo = cargo;
        this.dependencia = dependencia;
        this.salarioFijo = salario;
    }

    public String toString() {
        return "Administrativo" + super.toSting() + "Cargo" + this.cargo + "Dependencia" + this.dependencia + "Salario" + this.salarioFijo + "Valor a pagar" + calcularSalario();
    }

    public int calcular Salario() {
        lond deduccion = (salarioFijo * this.PORDEDUCCION/100);
        int valorPagar = (int) (salarioFijo-deduccion);
        return valorPagar;
    }
}
